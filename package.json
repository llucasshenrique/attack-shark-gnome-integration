{
  "name": "cli",
  "version": "0.1.3",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "test-session": "dbus-run-session gnome-shell --devkit --wayland   ",
    "cli": "bun run ./cli/index.ts",
    "test": "bun test",
    "clean": "rm -rf dist",
    "build:bin": "mkdir -p dist && bun build --target bun --compile --outfile dist/attack-shark-cli cli/index.ts && chmod +x dist/attack-shark-cli",
    "build:esm": "mkdir -p dist && bun build --target bun --format esm --outfile dist/attack-shark-cli.mjs cli/index.ts",
    "compile": "bun run clean && bun run build:bin && bun run build:esm",
    "package:deb": "bun run compile && sh ./scripts/package-deb.sh",
    "package:rpm": "bun run compile && sh ./scripts/package-rpm.sh",
    "package:linux": "bun run compile && sh ./scripts/package-deb.sh && sh ./scripts/package-rpm.sh",
    "test:packages:containers": "sh ./scripts/test-packages-containers.sh",
    "copy-extension": "cp -r extension dist/extension",
    "copy-cli": "cp -r dist/attack-shark-cli dist/extension/attack-shark-cli",
    "package": "bun clean && bun compile && bun copy-extension && bun copy-cli",
    "postpackage": "sh ./scripts/install-extension.sh"
  },
  "devDependencies": {
    "vitest": "^1.0.0",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "attack-shark-x11-driver": "github:HarukaYamamoto0/attack-shark-x11-driver"
  }
}
